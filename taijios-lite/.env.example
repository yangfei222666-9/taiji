# TaijiOS Lite 配置模板
# 复制本文件为 .env，填入你的 Key 即可

# ── AI 模型（选一个填就行）────────────────────────
# DeepSeek（推荐，便宜好用）：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-你的key填这里

# 模型设置（可选，默认DeepSeek）
# API_PROVIDER=DeepSeek
# API_BASE_URL=https://api.deepseek.com
# API_MODEL=deepseek-chat

# ── 飞书 Bot（可选）──────────────────────────────
# FEISHU_APP_ID=你的App_ID
# FEISHU_APP_SECRET=你的App_Secret

# ── Telegram Bot（可选）──────────────────────────
# TELEGRAM_BOT_TOKEN=你的Bot_Token
